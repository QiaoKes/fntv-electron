{
    "name": "fntv",
    "version": "1.7.3",
    "description": "A fntv app built with Electron",
    "main": "dest/main/main.js",
    "scripts": {
        "start": "tsc && electron .",
        "compile": "tsc",
        "watch": "tsc --watch",
        "clean": "rimraf dest",
        "build": "tsc && electron-builder"
    },
    "author": "tracing",
    "devDependencies": {
        "@types/cacheable-request": "^6.0.3",
        "@types/debug": "^4.1.12",
        "@types/fs-extra": "^11.0.4",
        "@types/http-cache-semantics": "^4.0.4",
        "@types/keyv": "^3.1.4",
        "@types/ms": "^2.1.0",
        "@types/node": "^20.19.11",
        "@types/plist": "^3.0.5",
        "@types/responselike": "^1.0.3",
        "@types/verror": "^1.10.11",
        "@types/yauzl": "^2.10.3",
        "copyfiles": "^2.4.1",
        "electron": "file:./third_party/electron",
        "electron-builder": "^26.0.12",
        "npm-run-all": "^4.1.5",
        "rimraf": "^5.0.9",
        "typescript": "^5.5.4"
    },
    "dependencies": {
        "axios": "^1.11.0",
        "semver": "^7.7.2"
    },
    "build": {
        "directories": {
            "output": "release"
        },
        "icon": "build/icon.ico",
        "productName": "飞牛影视",
        "artifactName": "FNMedia_${version}_${os}_${arch}.${ext}",
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "allowToChangeInstallationDirectory": true,
            "oneClick": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "files": [
            "dest",
            "build"
        ],
        "extraFiles": [
            {
                "from": "third_party/fntv-mpv",
                "to": "third_party/fntv-mpv",
                "filter": [
                    "**/*"
                ]
            }
        ]
    }
}
