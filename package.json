{
    "name": "fntv",
    "version": "1.7.1",
    "description": "A fntv app built with Electron",
    "main": "src/main/main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "author": "tracing",
    "devDependencies": {
        "electron": "file:./third_party/electron",
        "electron-builder": "^26.0.12"
    },
    "dependencies": {
        "axios": "^1.11.0",
        "semver": "^7.7.2"
    },
    "build": {
        "directories": {
            "output": "release"
        },
        "icon": "build/icon.ico",
        "productName": "飞牛影视",
        "artifactName": "FNMedia_${version}_${os}_${arch}.${ext}",
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "allowToChangeInstallationDirectory": true,
            "oneClick": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "files": [
            "src",
            "build"
        ],
        "extraFiles": [
            {
                "from": "third_party/fntv-mpv",
                "to": "third_party/fntv-mpv",
                "filter": [
                    "**/*"
                ]
            }
        ]
    }
}
