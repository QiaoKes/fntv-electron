{
    "name": "fntv",
    "version": "1.1.0",
    "description": "A fntv app built with Electron",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "author": "tracing",
    "devDependencies": {
        "electron": "file:./third_party/electron",
        "electron-builder": "^26.0.12"
    },
    "dependencies": {
        "axios": "^1.11.0"
    },
    "build": {
        "directories": {
            "output": "build"
        },
        "icon": "icon.ico",
        "productName": "飞牛影视",
        "artifactName": "FNMedia_${version}_https_nas.test.com_3400.${ext}",
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "include": "installer.nsh",
            "allowToChangeInstallationDirectory": true,
            "oneClick": false,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        },
        "files": [
            "*.js",
            "installer.nsh"
        ],
        "extraFiles": [
            {
                "from": "third_party/mpv",
                "to": "third_party/mpv",
                "filter": [
                    "**/*"
                ]
            }
        ]
    }
}